' ============================================================================
' SEQUENCE DIAGRAM 1: Task Assignment Flow
' ============================================================================

@startuml SequenceDiagram_TaskFlow
!theme plain
skinparam sequenceActorBackgroundColor #FFE6CC
skinparam sequenceParticipantBackgroundColor #E6F2FF
skinparam arrowColor #333

title Task Assignment and Completion Flow

actor Admin
participant "TaskController" as TC
participant "TaskService" as TS
participant "TaskRepository" as TR
participant "NotificationService" as NS
participant "EmailService" as ES
actor User

Admin -> TC: createTask(title, description)
TC -> TS: saveTask()
TS -> TR: save(Task)
TR --> TS: task (id)
TS --> TC: task
TC --> Admin: taskId

Admin -> TC: assignTask(taskId, userId)
TC -> TS: assignTaskToUser()
TS -> TR: update(Task)
TS -> NS: createNotification()
NS --> TS: notification
TS -> ES: sendEmail()
ES --> TS: email
TS --> TC: Task (assigned)
TC --> Admin: success

User -> TC: getAssignedTasks()
TC -> TS: getTasksByUserId()
TS -> TR: findByAssignedToUserId()
TR --> TS: tasks
TS --> TC: tasks
TC --> User: [tasks]

User -> TC: submitResponse(taskId, response)
TC -> TS: updateTaskResponse()
TS -> TR: update(Task)
TS -> NS: createNotification()
NS --> TS: notification
TS --> TC: Task (updated)
TC --> User: success

@enduml


' ============================================================================
' SEQUENCE DIAGRAM 2: Messaging Flow
' ============================================================================

@startuml SequenceDiagram_Messaging
!theme plain
skinparam sequenceActorBackgroundColor #FFE6CC
skinparam sequenceParticipantBackgroundColor #E6F2FF
skinparam arrowColor #333

title User-Admin Messaging Flow

actor User
participant "MessageController" as MC
participant "ChatProducer" as CP
participant "RabbitMQ" as RMQ
participant "ChatConsumer" as CC
participant "ChatMessageRepository" as CMR
participant "WebSocket" as WS
actor Admin

User -> MC: sendMessage(receiverId, content)
MC -> CP: publishMessage()
CP -> RMQ: sendToQueue()
RMQ --> CC: message

CC -> CMR: save(ChatMessage)
CMR --> CC: chatMessage
CC -> WS: broadcastMessage()
WS --> Admin: message (real-time)
WS --> User: confirmation

Admin -> WS: sendMessage(userId, content)
WS -> CP: publishMessage()
CP -> RMQ: sendToQueue()
RMQ --> CC: message
CC -> CMR: save(ChatMessage)
CC -> WS: broadcastMessage()
WS --> User: message (real-time)

User -> MC: getChatHistory(adminId)
MC -> CMR: findMessagesBy()
CMR --> MC: [ChatMessage]
MC --> User: messages

@enduml


' ============================================================================
' SEQUENCE DIAGRAM 3: Notification Flow
' ============================================================================

@startuml SequenceDiagram_Notifications
!theme plain
skinparam sequenceActorBackgroundColor #FFE6CC
skinparam sequenceParticipantBackgroundColor #E6F2FF
skinparam arrowColor #333

title Notification Creation and Delivery Flow

participant "TaskService" as TS
participant "NotificationService" as NS
participant "NotificationRepository" as NR
participant "EmailService" as ES
participant "WebSocket" as WS
actor User

TS -> NS: createNotification(userId, title, message)
NS -> NR: save(Notification)
NR --> NS: notification
NS -> WS: pushNotification()
WS --> User: notification (real-time)

alt Email Notification
    NS -> ES: sendEmail(userId, subject, message)
    ES --> NS: emailSent
end

User -> NS: getNotifications()
NS -> NR: findByUserId(userId)
NR --> NS: [Notification]
NS --> User: notifications

User -> NS: markAsRead(notificationId)
NS -> NR: update(notification)
NR --> NS: notification
NS --> User: success

note over TS, User
    Notifications triggered by:
    - Task assignment
    - Task completion
    - New messages
    - System events
end note

@enduml


' ============================================================================
' SEQUENCE DIAGRAM 4: Authentication Flow
' ============================================================================

@startuml SequenceDiagram_Auth
!theme plain
skinparam sequenceActorBackgroundColor #FFE6CC
skinparam sequenceParticipantBackgroundColor #E6F2FF
skinparam arrowColor #333

title User Authentication and Registration

actor Client
participant "AuthenticationController" as AC
participant "AuthService" as AS
participant "UserRepository" as UR
participant "TokenProvider" as TP

Client -> AC: register(email, firstName, lastName, password)
AC -> AS: registerUser()
AS -> UR: findByEmail()
UR --> AS: null
AS -> UR: save(User)
UR --> AS: user
AS --> AC: user
AC --> Client: success (userId)

Client -> AC: login(email, password)
AC -> AS: authenticateUser()
AS -> UR: findByEmail()
UR --> AS: user
AS -> AS: verifyPassword()
AS -> TP: generateToken()
TP --> AS: jwtToken
AS --> AC: token
AC --> Client: {token, user}

Client -> AC: validateToken()
AC -> TP: validateToken()
TP --> AC: valid
AC --> Client: {valid, userData}

@enduml
