' ============================================================================
' BACKEND MODELS - CLASS DIAGRAM
' ============================================================================

@startuml ClassDiagram
!theme plain
skinparam classBackgroundColor #F0F0F0
skinparam classBorderColor #333
skinparam arrowColor #333

' ---- ENTITIES ----

class User {
    - id: Integer
    - email: String
    - firstName: String
    - lastName: String
    - secretPassword: String
    - userActive: Boolean
    - createdAt: LocalDateTime
    --
    + getId(): Integer
    + getEmail(): String
    + getFirstName(): String
    + getLastName(): String
    + getUserActive(): Boolean
    + getCreatedAt(): LocalDateTime
    + setEmail(String): void
    + setFirstName(String): void
    + setLastName(String): void
    + setUserActive(Boolean): void
}

class Task {
    - id: Integer
    - status: String
    - title: String
    - description: String
    - assignedToUserId: Integer
    - createdAt: LocalDateTime
    - userResponse: String
    - responseAt: LocalDateTime
    --
    + getId(): Integer
    + getStatus(): String
    + getTitle(): String
    + getDescription(): String
    + getAssignedToUserId(): Integer
    + getCreatedAt(): LocalDateTime
    + getUserResponse(): String
    + getResponseAt(): LocalDateTime
    + setStatus(String): void
    + setTitle(String): void
}

class ChatMessage {
    - id: Integer
    - senderId: Integer
    - receiverId: Integer
    - senderRole: String
    - content: String
    - createdAt: LocalDateTime
    - read: Boolean
    --
    + getId(): Integer
    + getSenderId(): Integer
    + getReceiverId(): Integer
    + getSenderRole(): String
    + getContent(): String
    + getCreatedAt(): LocalDateTime
    + getRead(): Boolean
    + setSenderId(Integer): void
    + setContent(String): void
    + setRead(Boolean): void
}

class Notification {
    - id: Integer
    - title: String
    - message: String
    - userId: Integer
    - isRead: boolean
    - createdAt: LocalDateTime
    --
    + getId(): Integer
    + getTitle(): String
    + getMessage(): String
    + getUserId(): Integer
    + isRead(): boolean
    + getCreatedAt(): LocalDateTime
    + setTitle(String): void
    + setMessage(String): void
    + setRead(boolean): void
}

' ---- DATA TRANSFER OBJECTS ----

class TaskComplete {
    - taskId: Integer
    - username: String
    --
    + getTaskId(): Integer
    + getUsername(): String
    + setTaskId(Integer): void
    + setUsername(String): void
}

class Email {
    - id: Long
    - toEmail: String
    - subject: String
    - status: String
    - sentAt: LocalDateTime
}

' ---- RELATIONSHIPS ----

Task "1" --> "1" User : assigned to
ChatMessage "1" --> "1" User : sent by (senderId)
ChatMessage "1" --> "1" User : received by (receiverId)
Notification "1" --> "1" User : notifies
TaskComplete "1" --> "1" Task : completes

note right of User
    Base user entity
    Supports inheritance
    (JOINED strategy)
end note

note right of Task
    Task assignment workflow
    Status: ASSIGNED, IN_PROGRESS,
            COMPLETED, etc.
end note

note right of ChatMessage
    Real-time messaging
    Between User and Admin
    Role-based communication
end note

note right of Notification
    User notifications
    Task-related or system
    Read/unread tracking
end note

@enduml


